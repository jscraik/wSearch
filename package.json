{
  "name": "@brainwav/wsearch-cli",
  "version": "0.1.9",
  "description": "brAInwav wSearch CLI - Query Wikidata via REST, SPARQL, and Action API with safe, script-friendly output.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/jscraik/wSearch.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "wsearch": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "npm audit --audit-level=moderate",
    "semgrep": "semgrep scan --config auto",
    "gitleaks": "gitleaks detect --source . --redact",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint:types": "tsc -p tsconfig.json --noEmit",
    "lint": "npm run lint:types",
    "check": "npm run lint:types && npm test",
    "lint:docs": "markdownlint-cli2",
    "docs:lint": "markdownlint-cli2",
    "lint:docs:fix": "markdownlint-cli2 --fix",
    "lint:docs:vale": "vale --config .vale.ini README.md docs references",
    "lint:docs:readability": "python3 scripts/check_readability.py README.md docs references",
    "lint:docs:brand": "python3 scripts/check_brand_guidelines.py --repo . --docs docs/ARCHITECTURE.md --docs docs/BRAND.md --docs docs/CONFIG.md --docs docs/DEVELOPMENT.md --docs docs/FAQ.md --docs docs/GETTING_STARTED.md --docs docs/README.md --docs docs/SECURITY.md --docs docs/TROUBLESHOOTING.md --docs docs/USAGE.md --docs references/BRAND_GUIDELINES.md --docs references/CHECKLIST.md --docs references/CODE_DOC_CHECKLIST.md",
    "prepublishOnly": "npm run lint:types && npm run test && npm run build",
    "preversion": "git branch --show-current | grep -q '^main$' || (echo 'Releases must occur on main' && exit 1) && npm run prepublishOnly",
    "postversion": "git push && git push --tags",
    "test:artifacts": "bash scripts/test-with-artifacts.sh all",
    "test:artifacts:unit": "bash scripts/test-with-artifacts.sh unit",
    "test:artifacts:integration": "bash scripts/test-with-artifacts.sh integration",
    "test:artifacts:e2e": "bash scripts/test-with-artifacts.sh e2e",
    "verify-work": "bash scripts/verify-work.sh",
    "verify-work:workspace": "bash scripts/verify-work.sh --workspace-governance"
  },
  "dependencies": {
    "yargs": "^18.0.0"
  },
  "overrides": {
    "smol-toml": "1.6.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/yargs": "^17.0.32",
    "markdownlint-cli2": "^0.22.0",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.2"
  },
  "license": "Apache-2.0",
  "simple-git-hooks": {
    "pre-commit": "npm run lint:types",
    "commit-msg": "node scripts/validate-commit-msg.js $1",
    "pre-push": "npm test"
  }
}
